default_platform(:ios)

platform :ios do

  # ── Lane compartido: construye y configura la API key ──────────────────────
  def api_key
    app_store_connect_api_key(
      key_id:       ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id:    ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: File.expand_path(
        "~/.appstoreconnect/private_keys/AuthKey_#{ENV["APP_STORE_CONNECT_KEY_ID"]}.p8"
      ),
      duration:     1200,
      in_house:     false,
    )
  end

  def build_number
    # En CI usa el número de run de GitHub Actions; local usa timestamp
    ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
  end

  # ── Beta: push a develop → TestFlight internal ────────────────────────────
  lane :beta do
    setup_ci if ENV["CI"]

    increment_build_number(
      build_number:   build_number,
      xcodeproj:      "iosApp.xcodeproj",
    )

    build_app(
      scheme:              "iosApp",
      workspace:           "iosApp.xcworkspace",
      configuration:       "Debug",
      export_method:       "app-store",
      export_xcargs:       "-allowProvisioningUpdates",
      output_directory:    "./build",
      output_name:         "TanayenAI-beta.ipa",
      clean:               true,
    )

    upload_to_testflight(
      api_key:                 api_key,
      ipa:                     "./build/TanayenAI-beta.ipa",
      distribute_external:     false,   # solo testers internos
      notify_external_testers: false,
      changelog:               "Build automático desde develop",
      skip_waiting_for_build_processing: true,
    )

    UI.success "✅ Beta subida a TestFlight correctamente"
  end

  # ── Release: push a main → TestFlight (beta cerrada) ──────────────────────
  lane :release do
    setup_ci if ENV["CI"]

    # Incrementar también el version number en releases
    increment_version_number(
      version_number: "1.0.#{build_number}",
      xcodeproj:      "iosApp.xcodeproj",
    )

    increment_build_number(
      build_number: build_number,
      xcodeproj:    "iosApp.xcodeproj",
    )

    build_app(
      scheme:            "iosApp",
      workspace:         "iosApp.xcworkspace",
      configuration:     "Release",
      export_method:     "app-store",
      export_xcargs:     "-allowProvisioningUpdates",
      output_directory:  "./build",
      output_name:       "TanayenAI-release.ipa",
      clean:             true,
    )

    upload_to_testflight(
      api_key:                 api_key,
      ipa:                     "./build/TanayenAI-release.ipa",
      distribute_external:     true,   # grupo "Familia"
      groups:                  ["Familia"],
      notify_external_testers: true,
      changelog:               "Nueva versión disponible 🌿",
      skip_waiting_for_build_processing: false,
    )

    UI.success "✅ Release subida a TestFlight correctamente"
  end
end
